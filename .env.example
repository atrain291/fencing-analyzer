# PostgreSQL
POSTGRES_USER=fencing
POSTGRES_PASSWORD=fencing
POSTGRES_DB=fencing_analyzer
DATABASE_URL=postgresql://fencing:fencing@postgres:5432/fencing_analyzer

# Redis
REDIS_URL=redis://redis:6379/0

# Object Storage (AWS S3 or Cloudflare R2)
S3_BUCKET=fencing-videos
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=  # Leave blank for AWS, set for R2: https://<account>.r2.cloudflarestorage.com

# Claude API
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Ports (host-side — container internal ports are fixed)
FRONTEND_PORT=5173
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
OLLAMA_PORT=11434

# App
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
